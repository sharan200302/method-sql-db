{
	"name": "DF_TITLE",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_TITLE",
						"type": "DatasetReference"
					},
					"name": "TITLEcsv"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_TITLE",
						"type": "DatasetReference"
					},
					"name": "TITLEsql"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          TitleCode as integer,",
				"          TitleDescription as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> TITLEcsv",
				"TITLEcsv sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          TitleCode as string,",
				"          TitleDescription as string",
				"     ),",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     mapColumn(",
				"          TitleCode,",
				"          TitleDescription",
				"     )) ~> TITLEsql"
			]
		}
	}
}